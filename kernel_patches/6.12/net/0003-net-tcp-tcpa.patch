From: System Administrator <admin@example.com>
Subject: [PATCH] net-tcp-tcpa: TCPA congestion control based on BBRv1

TCPA is a congestion control algorithm based on BBRv1, but with a specific
optimization for local/remote ports 80 and 443, setting the initial CWND to 100.

Signed-off-by: System Administrator <admin@example.com>
---
 net/ipv4/Kconfig    |   10 +
 net/ipv4/Makefile   |    1 +
 net/ipv4/tcp_tcpa.c | 1230 +++++++++++++++++++++++++++++++++++++++++
 3 files changed, 1241 insertions(+)
 create mode 100644 net/ipv4/tcp_tcpa.c

diff --git a/net/ipv4/Kconfig b/net/ipv4/Kconfig
index ddc116ef22cb..30a881187e30 100644
--- a/net/ipv4/Kconfig
+++ b/net/ipv4/Kconfig
@@ -737,6 +737,13 @@ config TCP_CONG_CDG
 	  CAIA Delay-Gradient (CDG) is a hybrid congestion control
 	  algorithm derived from CAIA Hamilton Delay-Gradient (CHDG).
 
+config TCP_CONG_TCPA
+	tristate "TCPA TCP"
+	default n
+	help
+	  TCPA congestion control based on BBRv1.
+	  Sets initial CWND to 100 for ports 80/443.
+
 config TCP_CONG_BBR
 	tristate "BBR TCP"
 	default y
diff --git a/net/ipv4/Makefile b/net/ipv4/Makefile
index ec36d2ec059e..1733e2df22eb 100644
--- a/net/ipv4/Makefile
+++ b/net/ipv4/Makefile
@@ -62,4 +62,5 @@ obj-$(CONFIG_INET_TCP_DIAG) += tcp_diag.o
 obj-$(CONFIG_TCP_CONG_BIC) += tcp_bic.o
 obj-$(CONFIG_TCP_CONG_CDG) += tcp_cdg.o
+obj-$(CONFIG_TCP_CONG_TCPA) += tcp_tcpa.o
 obj-$(CONFIG_TCP_CONG_CUBIC) += tcp_cubic.o
 obj-$(CONFIG_TCP_CONG_DCTCP) += tcp_dctcp.o
diff --git a/net/ipv4/tcp_tcpa.c b/net/ipv4/tcp_tcpa.c
new file mode 100644
index 000000000000..0992ec0b4d89
--- /dev/null
+++ b/net/ipv4/tcp_tcpa.c
@@ -0,0 +1,908 @@
+/* TCPA (BBR based) congestion control
+ *
+ * BBR/TCPA congestion control computes the sending rate based on the delivery
+ * rate (throughput) estimated from ACKs.
+ *
+ * TCPA modification: Sets initial CWND to 100 for ports 80/443.
+ */
+#include <linux/btf.h>
+#include <linux/btf_ids.h>
+#include <linux/module.h>
+#include <net/tcp.h>
+#include <linux/inet_diag.h>
+#include <linux/inet.h>
+#include <linux/random.h>
+#include <linux/win_minmax.h>
+
+#define TCPA_INIT_CWND 100
+
+#define BW_SCALE 24
+#define BW_UNIT (1 << BW_SCALE)
+
+#define TCPA_SCALE 8	/* scaling factor for fractions in TCPA (e.g. gains) */
+#define TCPA_UNIT (1 << TCPA_SCALE)
+
+/* TCPA has the following modes for deciding how fast to send: */
+enum tcpa_mode {
+	TCPA_STARTUP,	/* ramp up sending rate rapidly to fill pipe */
+	TCPA_DRAIN,	/* drain any queue created during startup */
+	TCPA_PROBE_BW,	/* discover, share bw: pace around estimated bw */
+	TCPA_PROBE_RTT,	/* cut inflight to min to probe min_rtt */
+};
+
+/* TCPA congestion control block */
+struct tcpa {
+	u32	min_rtt_us;	        /* min RTT in min_rtt_win_sec window */
+	u32	min_rtt_stamp;	        /* timestamp of min_rtt_us */
+	u32	probe_rtt_done_stamp;   /* end time for TCPA_PROBE_RTT mode */
+	struct minmax bw;	/* Max recent delivery rate in pkts/uS << 24 */
+	u32	rtt_cnt;	    /* count of packet-timed rounds elapsed */
+	u32     next_rtt_delivered; /* scb->tx.delivered at end of round */
+	u64	cycle_mstamp;	     /* time of this cycle phase start */
+	u32     mode:3,		     /* current tcpa_mode in state machine */
+		prev_ca_state:3,     /* CA state on previous ACK */
+		packet_conservation:1,  /* use packet conservation? */
+		round_start:1,	     /* start of packet-timed tx->ack round? */
+		idle_restart:1,	     /* restarting after idle? */
+		probe_rtt_round_done:1,  /* a TCPA_PROBE_RTT round at 4 pkts? */
+		unused:13,
+		lt_is_sampling:1,    /* taking long-term ("LT") samples now? */
+		lt_rtt_cnt:7,	     /* round trips in long-term interval */
+		lt_use_bw:1;	     /* use lt_bw as our bw estimate? */
+	u32	lt_bw;		     /* LT est delivery rate in pkts/uS << 24 */
+	u32	lt_last_delivered;   /* LT intvl start: tp->delivered */
+	u32	lt_last_stamp;	     /* LT intvl start: tp->delivered_mstamp */
+	u32	lt_last_lost;	     /* LT intvl start: tp->lost */
+	u32	pacing_gain:10,	/* current gain for setting pacing rate */
+		cwnd_gain:10,	/* current gain for setting cwnd */
+		full_bw_reached:1,   /* reached full bw in Startup? */
+		full_bw_cnt:2,	/* number of rounds without large bw gains */
+		cycle_idx:3,	/* current index in pacing_gain cycle array */
+		has_seen_rtt:1, /* have we seen an RTT sample yet? */
+		unused_b:5;
+	u32	prior_cwnd;	/* prior cwnd upon entering loss recovery */
+	u32	full_bw;	/* recent bw, to estimate if pipe is full */
+
+	/* For tracking ACK aggregation: */
+	u64	ack_epoch_mstamp;	/* start of ACK sampling epoch */
+	u16	extra_acked[2];		/* max excess data ACKed in epoch */
+	u32	ack_epoch_acked:20,	/* packets (S)ACKed in sampling epoch */
+		extra_acked_win_rtts:5,	/* age of extra_acked, in round trips */
+		extra_acked_win_idx:1,	/* current index in extra_acked array */
+		unused_c:6;
+};
+
+#define CYCLE_LEN	8	/* number of phases in a pacing gain cycle */
+
+/* Window length of bw filter (in rounds): */
+static const int tcpa_bw_rtts = CYCLE_LEN + 2;
+/* Window length of min_rtt filter (in sec): */
+static const u32 tcpa_min_rtt_win_sec = 10;
+/* Minimum time (in ms) spent at tcpa_cwnd_min_target in TCPA_PROBE_RTT mode: */
+static const u32 tcpa_probe_rtt_mode_ms = 200;
+/* Skip TSO below the following bandwidth (bits/sec): */
+static const int tcpa_min_tso_rate = 1200000;
+
+static const int tcpa_pacing_margin_percent = 1;
+
+static const int tcpa_high_gain  = TCPA_UNIT * 2885 / 1000 + 1;
+static const int tcpa_drain_gain = TCPA_UNIT * 1000 / 2885;
+static const int tcpa_cwnd_gain  = TCPA_UNIT * 2;
+static const int tcpa_pacing_gain[] = {
+	TCPA_UNIT * 5 / 4,
+	TCPA_UNIT * 3 / 4,
+	TCPA_UNIT, TCPA_UNIT, TCPA_UNIT,
+	TCPA_UNIT, TCPA_UNIT, TCPA_UNIT
+};
+static const u32 tcpa_cycle_rand = 7;
+static const u32 tcpa_cwnd_min_target = 4;
+static const u32 tcpa_full_bw_thresh = TCPA_UNIT * 5 / 4;
+static const u32 tcpa_full_bw_cnt = 3;
+static const u32 tcpa_lt_intvl_min_rtts = 4;
+static const u32 tcpa_lt_loss_thresh = 50;
+static const u32 tcpa_lt_bw_ratio = TCPA_UNIT / 8;
+static const u32 tcpa_lt_bw_diff = 4000 / 8;
+static const u32 tcpa_lt_bw_max_rtts = 48;
+static const int tcpa_extra_acked_gain = TCPA_UNIT;
+static const u32 tcpa_extra_acked_win_rtts = 5;
+static const u32 tcpa_ack_epoch_acked_reset_thresh = 1U << 20;
+static const u32 tcpa_extra_acked_max_us = 100 * 1000;
+
+static void tcpa_check_probe_rtt_done(struct sock *sk);
+
+static bool tcpa_full_bw_reached(const struct sock *sk)
+{
+	const struct tcpa *tcpa = inet_csk_ca(sk);
+	return tcpa->full_bw_reached;
+}
+
+static u32 tcpa_max_bw(const struct sock *sk)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	return minmax_get(&tcpa->bw);
+}
+
+static u32 tcpa_bw(const struct sock *sk)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	return tcpa->lt_use_bw ? tcpa->lt_bw : tcpa_max_bw(sk);
+}
+
+static u16 tcpa_extra_acked(const struct sock *sk)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	return max(tcpa->extra_acked[0], tcpa->extra_acked[1]);
+}
+
+static u64 tcpa_rate_bytes_per_sec(struct sock *sk, u64 rate, int gain)
+{
+	unsigned int mss = tcp_sk(sk)->mss_cache;
+
+	rate *= mss;
+	rate *= gain;
+	rate >>= TCPA_SCALE;
+	rate *= USEC_PER_SEC / 100 * (100 - tcpa_pacing_margin_percent);
+	return rate >> BW_SCALE;
+}
+
+static unsigned long tcpa_bw_to_pacing_rate(struct sock *sk, u32 bw, int gain)
+{
+	u64 rate = bw;
+	rate = tcpa_rate_bytes_per_sec(sk, rate, gain);
+	rate = min_t(u64, rate, sk->sk_max_pacing_rate);
+	return rate;
+}
+
+static void tcpa_init_pacing_rate_from_rtt(struct sock *sk)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	u64 bw;
+	u32 rtt_us;
+
+	if (tp->srtt_us) {
+		rtt_us = max(tp->srtt_us >> 3, 1U);
+		tcpa->has_seen_rtt = 1;
+	} else {
+		rtt_us = USEC_PER_MSEC;
+	}
+	bw = (u64)tcp_snd_cwnd(tp) * BW_UNIT;
+	do_div(bw, rtt_us);
+	sk->sk_pacing_rate = tcpa_bw_to_pacing_rate(sk, bw, tcpa_high_gain);
+}
+
+static void tcpa_set_pacing_rate(struct sock *sk, u32 bw, int gain)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	unsigned long rate = tcpa_bw_to_pacing_rate(sk, bw, gain);
+
+	if (unlikely(!tcpa->has_seen_rtt && tp->srtt_us))
+		tcpa_init_pacing_rate_from_rtt(sk);
+	if (tcpa_full_bw_reached(sk) || rate > sk->sk_pacing_rate)
+		sk->sk_pacing_rate = rate;
+}
+
+static u32 tcpa_min_tso_segs(struct sock *sk)
+{
+	return sk->sk_pacing_rate < (tcpa_min_tso_rate >> 3) ? 1 : 2;
+}
+
+__bpf_kfunc static u32 tcpa_tso_segs(struct sock *sk, unsigned int mss_now)
+{
+	u32 min_tso, tso_segs;
+	min_tso = tcpa_min_tso_segs(sk);
+	tso_segs = tcp_tso_autosize(sk, mss_now, min_tso);
+	return min_t(u32, tso_segs, sk->sk_gso_max_segs);
+}
+
+static u32 tcpa_tso_segs_goal(struct sock *sk)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	u32 segs, bytes;
+	bytes = min_t(unsigned long,
+		      sk->sk_pacing_rate >> READ_ONCE(sk->sk_pacing_shift),
+		      GSO_LEGACY_MAX_SIZE - 1 - MAX_TCP_HEADER);
+	segs = max_t(u32, bytes / tp->mss_cache, tcpa_min_tso_segs(sk));
+	return min(segs, 0x7FU);
+}
+
+static void tcpa_save_cwnd(struct sock *sk)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+
+	if (tcpa->prev_ca_state < TCP_CA_Recovery && tcpa->mode != TCPA_PROBE_RTT)
+		tcpa->prior_cwnd = tcp_snd_cwnd(tp);
+	else
+		tcpa->prior_cwnd = max(tcpa->prior_cwnd, tcp_snd_cwnd(tp));
+}
+
+__bpf_kfunc static void tcpa_cwnd_event(struct sock *sk, enum tcp_ca_event event)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+
+	if (event == CA_EVENT_TX_START && tp->app_limited) {
+		tcpa->idle_restart = 1;
+		tcpa->ack_epoch_mstamp = tp->tcp_mstamp;
+		tcpa->ack_epoch_acked = 0;
+		if (tcpa->mode == TCPA_PROBE_BW)
+			tcpa_set_pacing_rate(sk, tcpa_bw(sk), TCPA_UNIT);
+		else if (tcpa->mode == TCPA_PROBE_RTT)
+			tcpa_check_probe_rtt_done(sk);
+	}
+}
+
+static u32 tcpa_bdp(struct sock *sk, u32 bw, int gain)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	u32 bdp;
+	u64 w;
+
+	if (unlikely(tcpa->min_rtt_us == ~0U))
+		return TCP_INIT_CWND;
+
+	w = (u64)bw * tcpa->min_rtt_us;
+	bdp = (((w * gain) >> TCPA_SCALE) + BW_UNIT - 1) / BW_UNIT;
+	return bdp;
+}
+
+static u32 tcpa_quantization_budget(struct sock *sk, u32 cwnd)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	cwnd += 3 * tcpa_tso_segs_goal(sk);
+	cwnd = (cwnd + 1) & ~1U;
+	if (tcpa->mode == TCPA_PROBE_BW && tcpa->cycle_idx == 0)
+		cwnd += 2;
+	return cwnd;
+}
+
+static u32 tcpa_inflight(struct sock *sk, u32 bw, int gain)
+{
+	u32 inflight;
+	inflight = tcpa_bdp(sk, bw, gain);
+	inflight = tcpa_quantization_budget(sk, inflight);
+	return inflight;
+}
+
+static u32 tcpa_packets_in_net_at_edt(struct sock *sk, u32 inflight_now)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	u64 now_ns, edt_ns, interval_us;
+	u32 interval_delivered, inflight_at_edt;
+
+	now_ns = tp->tcp_clock_cache;
+	edt_ns = max(tp->tcp_wstamp_ns, now_ns);
+	interval_us = div_u64(edt_ns - now_ns, NSEC_PER_USEC);
+	interval_delivered = (u64)tcpa_bw(sk) * interval_us >> BW_SCALE;
+	inflight_at_edt = inflight_now;
+	if (tcpa->pacing_gain > TCPA_UNIT)
+		inflight_at_edt += tcpa_tso_segs_goal(sk);
+	if (interval_delivered >= inflight_at_edt)
+		return 0;
+	return inflight_at_edt - interval_delivered;
+}
+
+static u32 tcpa_ack_aggregation_cwnd(struct sock *sk)
+{
+	u32 max_aggr_cwnd, aggr_cwnd = 0;
+
+	if (tcpa_extra_acked_gain && tcpa_full_bw_reached(sk)) {
+		max_aggr_cwnd = ((u64)tcpa_bw(sk) * tcpa_extra_acked_max_us)
+				/ BW_UNIT;
+		aggr_cwnd = (tcpa_extra_acked_gain * tcpa_extra_acked(sk))
+			     >> TCPA_SCALE;
+		aggr_cwnd = min(aggr_cwnd, max_aggr_cwnd);
+	}
+	return aggr_cwnd;
+}
+
+static bool tcpa_set_cwnd_to_recover_or_restore(
+	struct sock *sk, const struct rate_sample *rs, u32 acked, u32 *new_cwnd)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	u8 prev_state = tcpa->prev_ca_state, state = inet_csk(sk)->icsk_ca_state;
+	u32 cwnd = tcp_snd_cwnd(tp);
+
+	if (rs->losses > 0)
+		cwnd = max_t(s32, cwnd - rs->losses, 1);
+
+	if (state == TCP_CA_Recovery && prev_state != TCP_CA_Recovery) {
+		tcpa->packet_conservation = 1;
+		tcpa->next_rtt_delivered = tp->delivered;
+		cwnd = tcp_packets_in_flight(tp) + acked;
+	} else if (prev_state >= TCP_CA_Recovery && state < TCP_CA_Recovery) {
+		cwnd = max(cwnd, tcpa->prior_cwnd);
+		tcpa->packet_conservation = 0;
+	}
+	tcpa->prev_ca_state = state;
+
+	if (tcpa->packet_conservation) {
+		*new_cwnd = max(cwnd, tcp_packets_in_flight(tp) + acked);
+		return true;
+	}
+	*new_cwnd = cwnd;
+	return false;
+}
+
+static void tcpa_set_cwnd(struct sock *sk, const struct rate_sample *rs,
+			 u32 acked, u32 bw, int gain)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	u32 cwnd = tcp_snd_cwnd(tp), target_cwnd = 0;
+
+	if (!acked)
+		goto done;
+
+	if (tcpa_set_cwnd_to_recover_or_restore(sk, rs, acked, &cwnd))
+		goto done;
+
+	target_cwnd = tcpa_bdp(sk, bw, gain);
+	target_cwnd += tcpa_ack_aggregation_cwnd(sk);
+	target_cwnd = tcpa_quantization_budget(sk, target_cwnd);
+
+	if (tcpa_full_bw_reached(sk))
+		cwnd = min(cwnd + acked, target_cwnd);
+	else if (cwnd < target_cwnd || tp->delivered < TCP_INIT_CWND)
+		cwnd = cwnd + acked;
+	cwnd = max(cwnd, tcpa_cwnd_min_target);
+
+done:
+	tcp_snd_cwnd_set(tp, min(cwnd, tp->snd_cwnd_clamp));
+	if (tcpa->mode == TCPA_PROBE_RTT)
+		tcp_snd_cwnd_set(tp, min(tcp_snd_cwnd(tp), tcpa_cwnd_min_target));
+}
+
+static bool tcpa_is_next_cycle_phase(struct sock *sk,
+				    const struct rate_sample *rs)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	bool is_full_length =
+		tcp_stamp_us_delta(tp->delivered_mstamp, tcpa->cycle_mstamp) >
+		tcpa->min_rtt_us;
+	u32 inflight, bw;
+
+	if (tcpa->pacing_gain == TCPA_UNIT)
+		return is_full_length;
+
+	inflight = tcpa_packets_in_net_at_edt(sk, rs->prior_in_flight);
+	bw = tcpa_max_bw(sk);
+
+	if (tcpa->pacing_gain > TCPA_UNIT)
+		return is_full_length &&
+			(rs->losses ||
+			 inflight >= tcpa_inflight(sk, bw, tcpa->pacing_gain));
+
+	return is_full_length ||
+		inflight <= tcpa_inflight(sk, bw, TCPA_UNIT);
+}
+
+static void tcpa_advance_cycle_phase(struct sock *sk)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+
+	tcpa->cycle_idx = (tcpa->cycle_idx + 1) & (CYCLE_LEN - 1);
+	tcpa->cycle_mstamp = tp->delivered_mstamp;
+}
+
+static void tcpa_update_cycle_phase(struct sock *sk,
+				   const struct rate_sample *rs)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+
+	if (tcpa->mode == TCPA_PROBE_BW && tcpa_is_next_cycle_phase(sk, rs))
+		tcpa_advance_cycle_phase(sk);
+}
+
+static void tcpa_reset_startup_mode(struct sock *sk)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	tcpa->mode = TCPA_STARTUP;
+}
+
+static void tcpa_reset_probe_bw_mode(struct sock *sk)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+
+	tcpa->mode = TCPA_PROBE_BW;
+	tcpa->cycle_idx = CYCLE_LEN - 1 - get_random_u32_below(tcpa_cycle_rand);
+	tcpa_advance_cycle_phase(sk);
+}
+
+static void tcpa_reset_mode(struct sock *sk)
+{
+	if (!tcpa_full_bw_reached(sk))
+		tcpa_reset_startup_mode(sk);
+	else
+		tcpa_reset_probe_bw_mode(sk);
+}
+
+static void tcpa_reset_lt_bw_sampling_interval(struct sock *sk)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+
+	tcpa->lt_last_stamp = div_u64(tp->delivered_mstamp, USEC_PER_MSEC);
+	tcpa->lt_last_delivered = tp->delivered;
+	tcpa->lt_last_lost = tp->lost;
+	tcpa->lt_rtt_cnt = 0;
+}
+
+static void tcpa_reset_lt_bw_sampling(struct sock *sk)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+
+	tcpa->lt_bw = 0;
+	tcpa->lt_use_bw = 0;
+	tcpa->lt_is_sampling = false;
+	tcpa_reset_lt_bw_sampling_interval(sk);
+}
+
+static void tcpa_lt_bw_interval_done(struct sock *sk, u32 bw)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	u32 diff;
+
+	if (tcpa->lt_bw) {
+		diff = abs(bw - tcpa->lt_bw);
+		if ((diff * TCPA_UNIT <= tcpa_lt_bw_ratio * tcpa->lt_bw) ||
+		    (tcpa_rate_bytes_per_sec(sk, diff, TCPA_UNIT) <=
+		     tcpa_lt_bw_diff)) {
+			tcpa->lt_bw = (bw + tcpa->lt_bw) >> 1;
+			tcpa->lt_use_bw = 1;
+			tcpa->pacing_gain = TCPA_UNIT;
+			tcpa->lt_rtt_cnt = 0;
+			return;
+		}
+	}
+	tcpa->lt_bw = bw;
+	tcpa_reset_lt_bw_sampling_interval(sk);
+}
+
+static void tcpa_lt_bw_sampling(struct sock *sk, const struct rate_sample *rs)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	u32 lost, delivered;
+	u64 bw;
+	u32 t;
+
+	if (tcpa->lt_use_bw) {
+		if (tcpa->mode == TCPA_PROBE_BW && tcpa->round_start &&
+		    ++tcpa->lt_rtt_cnt >= tcpa_lt_bw_max_rtts) {
+			tcpa_reset_lt_bw_sampling(sk);
+			tcpa_reset_probe_bw_mode(sk);
+		}
+		return;
+	}
+
+	if (!tcpa->lt_is_sampling) {
+		if (!rs->losses)
+			return;
+		tcpa_reset_lt_bw_sampling_interval(sk);
+		tcpa->lt_is_sampling = true;
+	}
+
+	if (rs->is_app_limited) {
+		tcpa_reset_lt_bw_sampling(sk);
+		return;
+	}
+
+	if (tcpa->round_start)
+		tcpa->lt_rtt_cnt++;
+	if (tcpa->lt_rtt_cnt < tcpa_lt_intvl_min_rtts)
+		return;
+	if (tcpa->lt_rtt_cnt > 4 * tcpa_lt_intvl_min_rtts) {
+		tcpa_reset_lt_bw_sampling(sk);
+		return;
+	}
+
+	if (!rs->losses)
+		return;
+
+	lost = tp->lost - tcpa->lt_last_lost;
+	delivered = tp->delivered - tcpa->lt_last_delivered;
+	if (!delivered || (lost << TCPA_SCALE) < tcpa_lt_loss_thresh * delivered)
+		return;
+
+	t = div_u64(tp->delivered_mstamp, USEC_PER_MSEC) - tcpa->lt_last_stamp;
+	if ((s32)t < 1)
+		return;
+	if (t >= ~0U / USEC_PER_MSEC) {
+		tcpa_reset_lt_bw_sampling(sk);
+		return;
+	}
+	t *= USEC_PER_MSEC;
+	bw = (u64)delivered * BW_UNIT;
+	do_div(bw, t);
+	tcpa_lt_bw_interval_done(sk, bw);
+}
+
+static void tcpa_update_bw(struct sock *sk, const struct rate_sample *rs)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	u64 bw;
+
+	tcpa->round_start = 0;
+	if (rs->delivered < 0 || rs->interval_us <= 0)
+		return;
+
+	if (!before(rs->prior_delivered, tcpa->next_rtt_delivered)) {
+		tcpa->next_rtt_delivered = tp->delivered;
+		tcpa->rtt_cnt++;
+		tcpa->round_start = 1;
+		tcpa->packet_conservation = 0;
+	}
+
+	tcpa_lt_bw_sampling(sk, rs);
+
+	bw = div64_long((u64)rs->delivered * BW_UNIT, rs->interval_us);
+
+	if (!rs->is_app_limited || bw >= tcpa_max_bw(sk)) {
+		minmax_running_max(&tcpa->bw, tcpa_bw_rtts, tcpa->rtt_cnt, bw);
+	}
+}
+
+static void tcpa_update_ack_aggregation(struct sock *sk,
+				       const struct rate_sample *rs)
+{
+	u32 epoch_us, expected_acked, extra_acked;
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	struct tcp_sock *tp = tcp_sk(sk);
+
+	if (!tcpa_extra_acked_gain || rs->acked_sacked <= 0 ||
+	    rs->delivered < 0 || rs->interval_us <= 0)
+		return;
+
+	if (tcpa->round_start) {
+		tcpa->extra_acked_win_rtts = min(0x1F,
+						tcpa->extra_acked_win_rtts + 1);
+		if (tcpa->extra_acked_win_rtts >= tcpa_extra_acked_win_rtts) {
+			tcpa->extra_acked_win_rtts = 0;
+			tcpa->extra_acked_win_idx = tcpa->extra_acked_win_idx ?
+						   0 : 1;
+			tcpa->extra_acked[tcpa->extra_acked_win_idx] = 0;
+		}
+	}
+
+	epoch_us = tcp_stamp_us_delta(tp->delivered_mstamp,
+				      tcpa->ack_epoch_mstamp);
+	expected_acked = ((u64)tcpa_bw(sk) * epoch_us) / BW_UNIT;
+
+	if (tcpa->ack_epoch_acked <= expected_acked ||
+	    (tcpa->ack_epoch_acked + rs->acked_sacked >=
+	     tcpa_ack_epoch_acked_reset_thresh)) {
+		tcpa->ack_epoch_acked = 0;
+		tcpa->ack_epoch_mstamp = tp->delivered_mstamp;
+		expected_acked = 0;
+	}
+
+	tcpa->ack_epoch_acked = min_t(u32, 0xFFFFF,
+				     tcpa->ack_epoch_acked + rs->acked_sacked);
+	extra_acked = tcpa->ack_epoch_acked - expected_acked;
+	extra_acked = min(extra_acked, tcp_snd_cwnd(tp));
+	if (extra_acked > tcpa->extra_acked[tcpa->extra_acked_win_idx])
+		tcpa->extra_acked[tcpa->extra_acked_win_idx] = extra_acked;
+}
+
+static void tcpa_check_full_bw_reached(struct sock *sk,
+				      const struct rate_sample *rs)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	u32 bw_thresh;
+
+	if (tcpa_full_bw_reached(sk) || !tcpa->round_start || rs->is_app_limited)
+		return;
+
+	bw_thresh = (u64)tcpa->full_bw * tcpa_full_bw_thresh >> TCPA_SCALE;
+	if (tcpa_max_bw(sk) >= bw_thresh) {
+		tcpa->full_bw = tcpa_max_bw(sk);
+		tcpa->full_bw_cnt = 0;
+		return;
+	}
+	++tcpa->full_bw_cnt;
+	tcpa->full_bw_reached = tcpa->full_bw_cnt >= tcpa_full_bw_cnt;
+}
+
+static void tcpa_check_drain(struct sock *sk, const struct rate_sample *rs)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+
+	if (tcpa->mode == TCPA_STARTUP && tcpa_full_bw_reached(sk)) {
+		tcpa->mode = TCPA_DRAIN;
+		tcp_sk(sk)->snd_ssthresh =
+				tcpa_inflight(sk, tcpa_max_bw(sk), TCPA_UNIT);
+	}
+	if (tcpa->mode == TCPA_DRAIN &&
+	    tcpa_packets_in_net_at_edt(sk, tcp_packets_in_flight(tcp_sk(sk))) <=
+	    tcpa_inflight(sk, tcpa_max_bw(sk), TCPA_UNIT))
+		tcpa_reset_probe_bw_mode(sk);
+}
+
+static void tcpa_check_probe_rtt_done(struct sock *sk)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+
+	if (!(tcpa->probe_rtt_done_stamp &&
+	      after(tcp_jiffies32, tcpa->probe_rtt_done_stamp)))
+		return;
+
+	tcpa->min_rtt_stamp = tcp_jiffies32;
+	tcp_snd_cwnd_set(tp, max(tcp_snd_cwnd(tp), tcpa->prior_cwnd));
+	tcpa_reset_mode(sk);
+}
+
+static void tcpa_update_min_rtt(struct sock *sk, const struct rate_sample *rs)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	bool filter_expired;
+
+	filter_expired = after(tcp_jiffies32,
+			       tcpa->min_rtt_stamp + tcpa_min_rtt_win_sec * HZ);
+	if (rs->rtt_us >= 0 &&
+	    (rs->rtt_us < tcpa->min_rtt_us ||
+	     (filter_expired && !rs->is_ack_delayed))) {
+		tcpa->min_rtt_us = rs->rtt_us;
+		tcpa->min_rtt_stamp = tcp_jiffies32;
+	}
+
+	if (tcpa_probe_rtt_mode_ms > 0 && filter_expired &&
+	    !tcpa->idle_restart && tcpa->mode != TCPA_PROBE_RTT) {
+		tcpa->mode = TCPA_PROBE_RTT;
+		tcpa_save_cwnd(sk);
+		tcpa->probe_rtt_done_stamp = 0;
+	}
+
+	if (tcpa->mode == TCPA_PROBE_RTT) {
+		tp->app_limited =
+			(tp->delivered + tcp_packets_in_flight(tp)) ? : 1;
+		if (!tcpa->probe_rtt_done_stamp &&
+		    tcp_packets_in_flight(tp) <= tcpa_cwnd_min_target) {
+			tcpa->probe_rtt_done_stamp = tcp_jiffies32 +
+				msecs_to_jiffies(tcpa_probe_rtt_mode_ms);
+			tcpa->probe_rtt_round_done = 0;
+			tcpa->next_rtt_delivered = tp->delivered;
+		} else if (tcpa->probe_rtt_done_stamp) {
+			if (tcpa->round_start)
+				tcpa->probe_rtt_round_done = 1;
+			if (tcpa->probe_rtt_round_done)
+				tcpa_check_probe_rtt_done(sk);
+		}
+	}
+	if (rs->delivered > 0)
+		tcpa->idle_restart = 0;
+}
+
+static void tcpa_update_gains(struct sock *sk)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+
+	switch (tcpa->mode) {
+	case TCPA_STARTUP:
+		tcpa->pacing_gain = tcpa_high_gain;
+		tcpa->cwnd_gain	 = tcpa_high_gain;
+		break;
+	case TCPA_DRAIN:
+		tcpa->pacing_gain = tcpa_drain_gain;
+		tcpa->cwnd_gain	 = tcpa_high_gain;
+		break;
+	case TCPA_PROBE_BW:
+		tcpa->pacing_gain = (tcpa->lt_use_bw ?
+				    TCPA_UNIT :
+				    tcpa_pacing_gain[tcpa->cycle_idx]);
+		tcpa->cwnd_gain	 = tcpa_cwnd_gain;
+		break;
+	case TCPA_PROBE_RTT:
+		tcpa->pacing_gain = TCPA_UNIT;
+		tcpa->cwnd_gain	 = TCPA_UNIT;
+		break;
+	default:
+		WARN_ONCE(1, "TCPA bad mode: %u\n", tcpa->mode);
+		break;
+	}
+}
+
+static void tcpa_update_model(struct sock *sk, const struct rate_sample *rs)
+{
+	tcpa_update_bw(sk, rs);
+	tcpa_update_ack_aggregation(sk, rs);
+	tcpa_update_cycle_phase(sk, rs);
+	tcpa_check_full_bw_reached(sk, rs);
+	tcpa_check_drain(sk, rs);
+	tcpa_update_min_rtt(sk, rs);
+	tcpa_update_gains(sk);
+}
+
+__bpf_kfunc static void tcpa_main(struct sock *sk, u32 ack, int flag,
+				  const struct rate_sample *rs)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	u32 bw;
+
+	tcpa_update_model(sk, rs);
+
+	bw = tcpa_bw(sk);
+	tcpa_set_pacing_rate(sk, bw, tcpa->pacing_gain);
+	tcpa_set_cwnd(sk, rs, rs->acked_sacked, bw, tcpa->cwnd_gain);
+}
+
+__bpf_kfunc static void tcpa_init(struct sock *sk)
+{
+	struct tcp_sock *tp = tcp_sk(sk);
+	struct tcpa *tcpa = inet_csk_ca(sk);
+	struct inet_sock *inet = inet_sk(sk);
+	u16 sport, dport;
+
+	tcpa->prior_cwnd = 0;
+	tp->snd_ssthresh = TCP_INFINITE_SSTHRESH;
+	tcpa->rtt_cnt = 0;
+	tcpa->next_rtt_delivered = tp->delivered;
+	tcpa->prev_ca_state = TCP_CA_Open;
+	tcpa->packet_conservation = 0;
+
+	tcpa->probe_rtt_done_stamp = 0;
+	tcpa->probe_rtt_round_done = 0;
+	tcpa->min_rtt_us = tcp_min_rtt(tp);
+	tcpa->min_rtt_stamp = tcp_jiffies32;
+
+	minmax_reset(&tcpa->bw, tcpa->rtt_cnt, 0);
+
+	/* TCPA Custom Init Logic */
+	sport = ntohs(inet->inet_sport);
+	dport = ntohs(inet->inet_dport);
+	if (sport == 80 || sport == 443 || dport == 80 || dport == 443) {
+		tp->snd_cwnd = TCPA_INIT_CWND;
+		pr_info("TCPA: Init sk=%p ports=%u/%u cwnd=%d\n", sk, sport, dport, TCPA_INIT_CWND);
+	} else {
+		pr_info("TCPA: Init sk=%p ports=%u/%u default cwnd\n", sk, sport, dport);
+	}
+
+	tcpa->has_seen_rtt = 0;
+	tcpa_init_pacing_rate_from_rtt(sk);
+
+	tcpa->round_start = 0;
+	tcpa->idle_restart = 0;
+	tcpa->full_bw_reached = 0;
+	tcpa->full_bw = 0;
+	tcpa->full_bw_cnt = 0;
+	tcpa->cycle_mstamp = 0;
+	tcpa->cycle_idx = 0;
+	tcpa_reset_lt_bw_sampling(sk);
+	tcpa_reset_startup_mode(sk);
+
+	tcpa->ack_epoch_mstamp = tp->tcp_mstamp;
+	tcpa->ack_epoch_acked = 0;
+	tcpa->extra_acked_win_rtts = 0;
+	tcpa->extra_acked_win_idx = 0;
+	tcpa->extra_acked[0] = 0;
+	tcpa->extra_acked[1] = 0;
+
+	cmpxchg(&sk->sk_pacing_status, SK_PACING_NONE, SK_PACING_NEEDED);
+}
+
+__bpf_kfunc static u32 tcpa_sndbuf_expand(struct sock *sk)
+{
+	return 3;
+}
+
+__bpf_kfunc static u32 tcpa_undo_cwnd(struct sock *sk)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+
+	tcpa->full_bw = 0;
+	tcpa->full_bw_cnt = 0;
+	tcpa_reset_lt_bw_sampling(sk);
+	return tcp_snd_cwnd(tcp_sk(sk));
+}
+
+__bpf_kfunc static u32 tcpa_ssthresh(struct sock *sk)
+{
+	tcpa_save_cwnd(sk);
+	return tcp_sk(sk)->snd_ssthresh;
+}
+
+static size_t tcpa_get_info(struct sock *sk, u32 ext, int *attr,
+			    union tcp_cc_info *info)
+{
+	if (ext & (1 << (INET_DIAG_BBRINFO - 1)) ||
+	    ext & (1 << (INET_DIAG_VEGASINFO - 1))) {
+		struct tcp_sock *tp = tcp_sk(sk);
+		struct tcpa *tcpa = inet_csk_ca(sk);
+		u64 bw = tcpa_bw(sk);
+
+		bw = bw * tp->mss_cache * USEC_PER_SEC >> BW_SCALE;
+		memset(&info->bbr, 0, sizeof(info->bbr));
+		info->bbr.bbr_bw_lo		= (u32)bw;
+		info->bbr.bbr_bw_hi		= (u32)(bw >> 32);
+		info->bbr.bbr_min_rtt		= tcpa->min_rtt_us;
+		info->bbr.bbr_pacing_gain	= tcpa->pacing_gain;
+		info->bbr.bbr_cwnd_gain		= tcpa->cwnd_gain;
+		*attr = INET_DIAG_BBRINFO;
+		return sizeof(info->bbr);
+	}
+	return 0;
+}
+
+__bpf_kfunc static void tcpa_set_state(struct sock *sk, u8 new_state)
+{
+	struct tcpa *tcpa = inet_csk_ca(sk);
+
+	if (new_state == TCP_CA_Loss) {
+		struct rate_sample rs = { .losses = 1 };
+
+		tcpa->prev_ca_state = TCP_CA_Loss;
+		tcpa->full_bw = 0;
+		tcpa->round_start = 1;
+		tcpa_lt_bw_sampling(sk, &rs);
+	}
+}
+
+static struct tcp_congestion_ops tcp_tcpa_cong_ops __read_mostly = {
+	.flags		= TCP_CONG_NON_RESTRICTED,
+	.name		= "tcpa",
+	.owner		= THIS_MODULE,
+	.init		= tcpa_init,
+	.cong_control	= tcpa_main,
+	.sndbuf_expand	= tcpa_sndbuf_expand,
+	.undo_cwnd	= tcpa_undo_cwnd,
+	.cwnd_event	= tcpa_cwnd_event,
+	.ssthresh	= tcpa_ssthresh,
+	.tso_segs	= tcpa_tso_segs,
+	.get_info	= tcpa_get_info,
+	.set_state	= tcpa_set_state,
+};
+
+BTF_KFUNCS_START(tcp_tcpa_check_kfunc_ids)
+BTF_ID_FLAGS(func, tcpa_init)
+BTF_ID_FLAGS(func, tcpa_main)
+BTF_ID_FLAGS(func, tcpa_sndbuf_expand)
+BTF_ID_FLAGS(func, tcpa_undo_cwnd)
+BTF_ID_FLAGS(func, tcpa_cwnd_event)
+BTF_ID_FLAGS(func, tcpa_ssthresh)
+BTF_ID_FLAGS(func, tcpa_tso_segs)
+BTF_ID_FLAGS(func, tcpa_set_state)
+BTF_KFUNCS_END(tcp_tcpa_check_kfunc_ids)
+
+static const struct btf_kfunc_id_set tcp_tcpa_kfunc_set = {
+	.owner = THIS_MODULE,
+	.set   = &tcp_tcpa_check_kfunc_ids,
+};
+
+static int __init tcpa_register(void)
+{
+	int ret;
+
+	BUILD_BUG_ON(sizeof(struct tcpa) > ICSK_CA_PRIV_SIZE);
+
+	ret = register_btf_kfunc_id_set(BPF_PROG_TYPE_STRUCT_OPS,
+					&tcp_tcpa_kfunc_set);
+	if (ret < 0)
+		return ret;
+	return tcp_register_congestion_control(&tcp_tcpa_cong_ops);
+}
+
+static void __exit tcpa_unregister(void)
+{
+	tcp_unregister_congestion_control(&tcp_tcpa_cong_ops);
+}
+
+module_init(tcpa_register);
+module_exit(tcpa_unregister);
